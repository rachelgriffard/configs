// Config profile metadata
params {
    config_profile_description = 'KU CRC (University of Kansas Center for Research Computing) biostat partition profile'
    config_profile_contact     = 'Rachel Griffard (@rachelgriffard)'
    config_profile_url         = 'https://docs.crc.ku.edu/'

    max_cpus   = 48
    max_memory = 250.GB
    max_time   = 10.d
}

// Internal variables for paths that come from user environment.
// Using System.getenv() so CI passes even without these vars set.
def scratch_dir = System.getenv('SCRATCH') ?: '/tmp'
def work_dir    = System.getenv('WORK') ?: '/tmp'

process {
    resourceLimits = [
        cpus:   48,
        memory: 250.GB,
        time:   240.h
    ]
    executor = 'slurm'
    queue    = 'biostat'
}

executor {
    queueSize       = 100
    submitRateLimit = '20/1min'
}

apptainer {
    enabled    = true
    autoMounts = true
    runOptions = "--bind ${work_dir} --bind ${scratch_dir}"
    cacheDir   = "${scratch_dir}/.apptainer/cache"
}

env {
    APPTAINER_CACHEDIR = "${scratch_dir}/.apptainer/cache"
    APPTAINER_TMPDIR   = "${scratch_dir}/.apptainer/tmp"
}
